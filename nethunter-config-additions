# NetHunter - HID Gadget
CONFIG_USB_F_HID=y
CONFIG_USB_CONFIGFS_F_HID=y

# NetHunter - Bluetooth
CONFIG_BT_VHCI=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_H4=y

# NetHunter - WiFi
CONFIG_MAC80211=y
CONFIG_CFG80211=y
CONFIG_WIRELESS_EXT=y
CONFIG_WEXT_PRIV=y
CONFIG_RFKILL=y
CONFIG_RT2800USB=y
CONFIG_RT73USB=y
CONFIG_RTL8187=y
CONFIG_CARL9170=y

# NetHunter - USB Serial
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_GENERIC=y
CONFIG_USB_SERIAL_PL2303=y
CONFIG_USB_SERIAL_CP210X=y
CONFIG_USB_SERIAL_FTDI_SIO=y
CONFIG_USB_SERIAL_OPTION=y
CONFIG_USB_ACM=y
CONFIG_USB_WDM=y

# NetHunter - Network
CONFIG_NET_IPIP=m
CONFIG_NET_IPGRE=m
CONFIG_NET_IPGRE_DEMUX=m
CONFIG_NETFILTER_XT_TARGET_TTL=y
CONFIG_NETFILTER_XT_TARGET_TCPMSS=y
CONFIG_NETFILTER_XT_MATCH_TTL=m
CONFIG_NETFILTER_XT_MATCH_STATE=y
CONFIG_IP_NF_TARGET_TTL=y
CONFIG_IP_NF_FTP=m
CONFIG_NF_NAT_FTP=m

# NetHunter - Filesystem
CONFIG_FUSE_FS=y
CONFIG_NFS_FS=m
CONFIG_NFS_V2=m
CONFIG_NFS_V3=m
CONFIG_CIFS=m

# NetHunter - IPC
CONFIG_SYSVIPC=y
CONFIG_SYSVIPC_SYSCTL=y
CONFIG_POSIX_MQUEUE=y
CONFIG_POSIX_MQUEUE_SYSCTL=y

# NetHunter - Kernel Config Access
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
